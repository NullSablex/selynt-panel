#!/usr/local/bin/php -n
<?php
require_once dirname(__DIR__, 2) . '/lib/common.php';

// Formato do arquivo: "path version" por linha (ex: "/usr/local/bin/node v20.15.1")
$nv_file = SELYNT_PLUGIN_DIR . '/etc/node_versions';
$versions = [];

if (file_exists($nv_file)) {
    foreach (file($nv_file) as $line) {
        $parts = preg_split('/\s+/', trim($line), 2);
        $path = $parts[0] ?? '';
        $ver  = $parts[1] ?? '';
        if ($path === '' || $path[0] !== '/') continue;
        $label = $ver !== '' ? ltrim($ver, 'v') : basename(dirname($path));
        $versions[] = ['path' => $path, 'version' => $ver, 'label' => $label];
    }
}

// Se nenhuma versão configurada, oferecer default do PATH
if (empty($versions)) {
    $ver = trim((string)shell_exec('node --version 2>/dev/null'));
    $label = $ver !== '' ? ltrim($ver, 'v') . ' (padrão)' : 'padrão do sistema';
    $versions[] = ['path' => '', 'version' => $ver, 'label' => $label];
}

selynt_json(['ok' => true, 'versions' => $versions]);
