#!/usr/local/bin/php -n
<?php
require_once dirname(__DIR__, 2) . '/lib/common.php';

$input  = selynt_input();
$action = $input['action'] ?? '';

if ($action === 'setup_ols') {
    selynt_require_post();
    $script = SELYNT_PLUGIN_DIR . '/scripts/setup-ols.sh';
    if (!is_executable($script)) {
        selynt_json(['ok' => false, 'error' => 'script_missing', 'message' => 'setup-ols.sh não encontrado ou não executável.']); exit(0);
    }
    $output = []; $exit_code = 0;
    exec('bash ' . escapeshellarg($script) . ' 2>&1', $output, $exit_code);
    selynt_json([
        'ok'      => $exit_code === 0,
        'output'  => implode("\n", $output),
        'message' => $exit_code !== 0 ? 'setup-ols.sh retornou erro (exit=' . $exit_code . ').' : null,
    ]); exit(0);
}

if ($action === 'version') {
    selynt_json(selynt_run(['admin', 'version'])); exit(0);
}

if ($action === 'detect_nodes') {
    selynt_json(selynt_run(['admin', 'detect-nodes'])); exit(0);
}

if ($action === 'allowed_versions') {
    $nv_file = SELYNT_PLUGIN_DIR . '/etc/node_versions';
    $versions = [];
    if (file_exists($nv_file)) {
        foreach (file($nv_file) as $line) {
            $parts = preg_split('/\s+/', trim($line), 2);
            if (!empty($parts[1])) $versions[] = $parts[1];
        }
    }
    selynt_json(['ok' => true, 'versions' => $versions]); exit(0);
}

if ($action === 'save_node_versions') {
    selynt_require_post();
    $s = trim((string)($input['s'] ?? ''));
    if ($s === '') {
        selynt_json(['ok' => false, 'error' => 'no_selection', 'message' => 'Nenhuma versão selecionada.']); exit(0);
    }
    $args = ['admin', 'save-node-versions'];
    foreach (explode('-', $s) as $idx) {
        $args[] = (string)(int)$idx;
    }
    selynt_json(selynt_run($args)); exit(0);
}

selynt_json(['ok' => false, 'error' => 'unknown_action']);
